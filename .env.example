OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\service-account.json
LOCAL_CACHE_DB_PATH=data/glacier_cache.db
CACHE_REFRESH_MINUTES=60
DATA_SOURCE_MODE=bigquery_direct
AUTO_SYNC_CACHE_ON_STARTUP=true
AUTO_SYNC_CACHE_INTERVAL=false
